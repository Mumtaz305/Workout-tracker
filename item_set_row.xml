<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginBottom="8dp">

    <!-- Set Number -->
    <TextView
        android:id="@+id/tvSetNum"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_set_num"
        android:gravity="center"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <!-- Previous value -->
    <TextView
        android:id="@+id/tvPrev"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:gravity="center"
        android:textColor="#333333"
        android:textSize="12sp"
        android:text="-"/>

    <!-- Field A (kg or min) -->
    <EditText
        android:id="@+id/etFieldA"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="4dp"
        android:background="@drawable/bg_input"
        android:gravity="center"
        android:inputType="numberDecimal"
        android:textColor="#F5F5F5"
        android:textSize="16sp"
        android:textStyle="bold"
        android:hint="0"
        android:hintTextColor="#333333"/>

    <!-- Field B (reps or speed) -->
    <EditText
        android:id="@+id/etFieldB"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="4dp"
        android:background="@drawable/bg_input"
        android:gravity="center"
        android:inputType="numberDecimal"
        android:textColor="#F5F5F5"
        android:textSize="16sp"
        android:textStyle="bold"
        android:hint="0"
        android:hintTextColor="#333333"/>

    <!-- Done checkbox -->
    <CheckBox
        android:id="@+id/cbDone"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:button="@android:drawable/checkbox_on_background"
        android:buttonTint="#E8FF00"
        android:layout_marginStart="4dp"/>

    <!-- Delete -->
    <ImageView
        android:id="@+id/btnDelSet"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#2A2A2A"
        android:padding="4dp"/>
</LinearLayout>
